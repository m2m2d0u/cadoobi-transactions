# =============================================================================
# Cadoobi Transactions - Environment Variables
# =============================================================================
# Copy this file to .env and update the values
# Usage: docker-compose --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SPRING_APPLICATION_NAME=cadoobi-transactions

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=cadoobi_transactions
POSTGRES_USER=cadoobi_user
POSTGRES_PASSWORD=cadoobi_pass_2024
POSTGRES_PORT=5432

# Database Connection Pool
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# -----------------------------------------------------------------------------
# Spring JPA Configuration
# -----------------------------------------------------------------------------
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE=UTC

# -----------------------------------------------------------------------------
# Flyway Configuration
# -----------------------------------------------------------------------------
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8081
APP_PORT=8081
SERVER_COMPRESSION_ENABLED=true

# -----------------------------------------------------------------------------
# Actuator & Monitoring
# -----------------------------------------------------------------------------
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
METRICS_PROMETHEUS_ENABLED=false

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Notification Settings
APP_NOTIFICATION_MAX_RETRY_ATTEMPTS=5
APP_NOTIFICATION_RETRY_DELAY_SECONDS=5,30,120,600,3600

# Gift Card Settings
APP_GIFT_CARD_CODE_LENGTH=12
APP_GIFT_CARD_EXPIRY_DAYS=365
APP_GIFT_CARD_QR_CODE_SIZE=300

# Payment Settings
APP_PAYMENT_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_SN_SYMMETRY_CADOOBI=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN

# -----------------------------------------------------------------------------
# Java Options
# -----------------------------------------------------------------------------
JAVA_OPTS=-Xmx512m -Xms256m

# -----------------------------------------------------------------------------
# PgAdmin Configuration (Optional)
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@cadoobi.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050
